# =============================================================================
# .env.example — KeyCompute 环境变量配置模板
#
# 使用方法：
#   cp .env.example .env
#   # 编辑 .env 填入实际值，.env 已被 .gitignore 排除
#
# 环境变量命名规范：
#   - KC__ 前缀：应用配置（双下划线分隔层级）
#   - 示例：KC__AUTH__JWT_SECRET 对应 config.toml 中的 auth.jwt_secret
#
# 警告：
#   - 生产环境中所有 "change-me" 占位符必须替换为真实安全值
#   - KC__CRYPTO__SECRET_KEY 一旦数据库写入数据后不可更改（会导致历史数据无法解密）
#   - KC__AUTH__JWT_SECRET 更换后所有已签发 Token 立即失效
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL 数据库配置
# ─────────────────────────────────────────────────────────────────────────────
# 数据库名称
POSTGRES_DB=keycompute
# 数据库用户名
POSTGRES_USER=keycompute
# 数据库密码（必需！生产环境使用强密码，建议 32 位以上随机字符串）
# 生成命令：openssl rand -base64 32
POSTGRES_PASSWORD=change-me-strong-password

# 数据库连接池配置（可选，默认值已足够大多数场景）
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# ─────────────────────────────────────────────────────────────────────────────
# Redis 缓存配置
# ─────────────────────────────────────────────────────────────────────────────
# Redis 密码（必需！）
# 生成命令：openssl rand -base64 32
REDIS_PASSWORD=change-me-redis-password
# Redis 连接池大小
REDIS_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────────────────────
# 应用配置 (KC__ 前缀)
# ─────────────────────────────────────────────────────────────────────────────

# === 认证配置 ===
# JWT 签名密钥（生产环境必须修改！更换后所有 Token 立即失效）
# 生成命令：openssl rand -base64 64
KC__AUTH__JWT_SECRET=change-me-jwt-secret-key
# JWT 签发者标识
KC__AUTH__JWT_ISSUER=keycompute
# Token 有效期（秒）默认 1 小时
KC__AUTH__JWT_EXPIRY_SECS=3600

# === 加密配置 ===
# API Key 存储加密密钥（Base64 编码的 32 字节密钥）
# 警告：数据库有数据后不可更换此密钥！
# 生成命令：openssl rand -base64 32
KC__CRYPTO__SECRET_KEY=change-me-base64-encoded-32-byte-key

# === 邮件服务配置 ===
# 用于发送邮箱验证、密码重置等邮件
KC__EMAIL__SMTP_HOST=smtp.example.com
KC__EMAIL__SMTP_PORT=587
KC__EMAIL__SMTP_USERNAME=noreply@example.com
KC__EMAIL__SMTP_PASSWORD=change-me-smtp-password
KC__EMAIL__FROM_ADDRESS=noreply@example.com
KC__EMAIL__FROM_NAME=KeyCompute
# 验证链接基础 URL（用于生成邮箱验证和密码重置链接）
KC__EMAIL__VERIFICATION_BASE_URL=https://example.com

# === Gateway 配置（可选，使用默认值即可）===
# 请求超时时间（秒）
# KC__GATEWAY__TIMEOUT_SECS=120
# HTTP 请求超时（秒）
# KC__GATEWAY__REQUEST_TIMEOUT_SECS=120
# 流式请求超时（秒）
# KC__GATEWAY__STREAM_TIMEOUT_SECS=600
# 最大重试次数
# KC__GATEWAY__MAX_RETRIES=3
# 是否启用 fallback
# KC__GATEWAY__ENABLE_FALLBACK=true

# === 分销配置（可选，使用默认值即可）===
# 一级分销默认比例
# KC__DISTRIBUTION__DEFAULT_LEVEL1_RATIO=0.03
# 二级分销默认比例
# KC__DISTRIBUTION__DEFAULT_LEVEL2_RATIO=0.02
# 最大总分销比例
# KC__DISTRIBUTION__MAX_TOTAL_RATIO=0.30

# === 数据库连接配置（可选，使用默认值即可）===
# 连接超时时间（秒）
# KC__DATABASE__CONNECT_TIMEOUT_SECS=30
# 空闲超时时间（秒）
# KC__DATABASE__IDLE_TIMEOUT_SECS=600
# 连接最大生命周期（秒）
# KC__DATABASE__MAX_LIFETIME_SECS=1800

# ─────────────────────────────────────────────────────────────────────────────
# 默认系统管理员配置（首次启动时自动创建）
# 警告：生产环境部署后请立即修改默认管理员密码！
# ─────────────────────────────────────────────────────────────────────────────
KC__DEFAULT_ADMIN_EMAIL=admin@keycompute.local
KC__DEFAULT_ADMIN_PASSWORD=12345

# ─────────────────────────────────────────────────────────────────────────────
# Web 服务配置
# ─────────────────────────────────────────────────────────────────────────────
# 前端 Web 服务对外绑定端口（默认 80）
# 生产环境建议在 Nginx/CDN 层处理 443/TLS，此处用 80
WEB_PORT=80

# ─────────────────────────────────────────────────────────────────────────────
# 本地 Ollama 配置
# ─────────────────────────────────────────────────────────────────────────────
# Ollama 对外暴露端口
OLLAMA_PORT=11434
# 容器启动后自动拉取并预热的模型
OLLAMA_MODEL=gemma3:270m
# Ollama 模型保活时间；设为 -1 表示常驻内存
OLLAMA_KEEP_ALIVE=30m
# 预热模型时发送的简短提示词
OLLAMA_WARMUP_PROMPT=You are KeyCompute's assistant, ready to help with any questions.
